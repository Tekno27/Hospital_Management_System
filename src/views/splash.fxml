<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="controllers.SplashController"
           prefWidth="900" prefHeight="560"
           styleClass="splash-root">

    <VBox fx:id="splashContent" alignment="CENTER" spacing="28" styleClass="splash-content">

        <HBox alignment="CENTER" spacing="18">
            <StackPane styleClass="splash-logo-circle">
                <Label text="✚" styleClass="splash-logo-icon"/>
            </StackPane>
            <VBox spacing="4" alignment="CENTER_LEFT">
                <Label text="MedCore" styleClass="splash-brand"/>
                <Label text="Hospital Management System" styleClass="splash-tagline"/>
            </VBox>
        </HBox>

        <Label text="Integrated care for patients, staff, and operations"
               styleClass="splash-subtitle"/>

        <HBox spacing="10" alignment="CENTER">
            <Label text="Patients" styleClass="splash-chip"/>
            <Label text="Pharmacy" styleClass="splash-chip"/>
            <Label text="Laboratory" styleClass="splash-chip"/>
            <Label text="Billing" styleClass="splash-chip"/>
            <Label text="Wards" styleClass="splash-chip"/>
        </HBox>

        <VBox spacing="10" alignment="CENTER" prefWidth="420">
            <ProgressBar fx:id="loadingBar" prefWidth="420" progress="0" styleClass="splash-progress"/>
            <Label fx:id="statusLabel" text="Initializing..." styleClass="splash-status"/>
        </VBox>

        <Label text="v1.0 · Role-based access · SQLite powered" styleClass="splash-footer"/>
    </VBox>
</StackPane>
