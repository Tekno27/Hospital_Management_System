<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.DoctorFormController"
      spacing="12" prefWidth="380"
      styleClass="form-root">

    <Label fx:id="formTitleLabel" text="Add Doctor" styleClass="form-title" />

    <TextField fx:id="fullNameField" promptText="Full name" />
    <TextField fx:id="specializationField" promptText="Specialization" />
    <TextField fx:id="departmentField" promptText="Department" />
    <TextField fx:id="phoneField" promptText="Phone number" />
    <TextField fx:id="emailField" promptText="Email" />

    <Label fx:id="formErrorLabel" styleClass="form-error" visible="false" wrapText="true" />

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCancel" styleClass="btn-secondary" />
        <Button text="Save" onAction="#handleSave" styleClass="btn-primary" />
    </HBox>

</VBox>
