<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.PatientController"
      spacing="0" styleClass="app-bg">

    <HBox alignment="CENTER_LEFT" spacing="8" prefHeight="64" styleClass="content-header">
        <VBox spacing="2">
            <Label text="Patients" styleClass="page-title"/>
            <Label fx:id="recordCountLabel" text="0 records" styleClass="record-count"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox spacing="0" VBox.vgrow="ALWAYS">
        <VBox prefWidth="250" minWidth="250" spacing="16" styleClass="filter-panel">
            <Label text="Filters &amp; Actions" styleClass="filter-section-title"/>
            <VBox spacing="8">
                <Label text="Search" styleClass="filter-label"/>
                <TextField fx:id="searchField" promptText="Name or phone..."/>
            </VBox>
            <VBox spacing="8">
                <Label text="Status" styleClass="filter-label"/>
                <ComboBox fx:id="statusFilter" promptText="All statuses" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="8">
                <Label text="Gender" styleClass="filter-label"/>
                <ComboBox fx:id="genderFilter" promptText="All genders" maxWidth="Infinity"/>
            </VBox>
            <HBox spacing="8">
                <Button text="Apply" onAction="#handleSearch" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="btn-primary"/>
                <Button text="Clear" onAction="#handleClearFilters" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="btn-secondary"/>
            </HBox>
            <Separator/>
            <Button fx:id="addPatientButton" text="+ Add Patient" onAction="#handleAdd" maxWidth="Infinity" styleClass="btn-accent"/>
        </VBox>

        <VBox VBox.vgrow="ALWAYS" styleClass="table-area">
            <TableView fx:id="patientTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="45" />
                    <TableColumn fx:id="colName" text="Name" prefWidth="160" />
                    <TableColumn fx:id="colGender" text="Gender" prefWidth="80" />
                    <TableColumn fx:id="colPhone" text="Phone" prefWidth="110" />
                    <TableColumn fx:id="colBloodGroup" text="Blood" prefWidth="70" />
                    <TableColumn fx:id="colDoctor" text="Doctor" prefWidth="150" />
                    <TableColumn fx:id="colWard" text="Ward" prefWidth="90" />
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="100" />
                    <TableColumn fx:id="colActions" text="Actions" prefWidth="140" />
                </columns>
                <placeholder>
                    <Label text="No patients match your filters." styleClass="muted-text"/>
                </placeholder>
            </TableView>
        </VBox>
    </HBox>
</VBox>
