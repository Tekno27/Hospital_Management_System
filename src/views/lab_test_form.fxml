<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.LabTestFormController"
      spacing="12" prefWidth="400"
      styleClass="form-root">

    <Label fx:id="formTitleLabel" text="Add Lab Test" styleClass="form-title" />
    <TextField fx:id="nameField" promptText="Test name" />
    <TextField fx:id="categoryField" promptText="Category" />
    <TextField fx:id="priceField" promptText="Price (GHS)" />
    <TextField fx:id="rangeField" promptText="Normal range" />
    <Label fx:id="formErrorLabel" styleClass="form-error" visible="false" wrapText="true" />
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCancel" styleClass="btn-secondary" />
        <Button text="Save" onAction="#handleSave" styleClass="btn-primary" />
    </HBox>
</VBox>
