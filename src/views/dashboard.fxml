<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.DashboardController"
      prefWidth="1100" prefHeight="680"
      style="-fx-background-color: #F4FBFF;">

    <VBox prefWidth="220" spacing="0"
          style="-fx-background-color: #EAF6FF; -fx-border-color: #D6ECFA; -fx-border-width: 0 1 0 0;">

        <VBox spacing="0"
              style="-fx-padding: 20 18 16 18; -fx-border-color: #D6ECFA; -fx-border-width: 0 0 1 0;">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <StackPane prefWidth="34" prefHeight="34"
                           style="-fx-background-color: #7CC8F8; -fx-background-radius: 8;">
                    <Label text="+" style="-fx-font-size: 20; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </StackPane>
                <VBox spacing="1">
                    <Label text="MedCore HMS"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #3D7FB8;"/>
                    <Label fx:id="portalLabel" text="Admin Portal"
                           style="-fx-font-size: 11; -fx-text-fill: #78BCE8;"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox spacing="2" style="-fx-padding: 14 10 0 10;">
            <Label text="MAIN" style="-fx-font-size: 10; -fx-text-fill: #78BCE8; -fx-padding: 0 8 6 8;"/>

            <HBox fx:id="dashboardNav" spacing="10" alignment="CENTER_LEFT"
                  style="-fx-background-color: #7CC8F8; -fx-background-radius: 8; -fx-padding: 9 10 9 10; -fx-cursor: hand;">
                <Label text="⊞" style="-fx-font-size: 15; -fx-text-fill: white;"/>
                <Label text="Dashboard" style="-fx-font-size: 13; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </HBox>

            <HBox fx:id="patientsNav" spacing="10" alignment="CENTER_LEFT"
                  style="-fx-padding: 9 10 9 10; -fx-cursor: hand; -fx-background-radius: 8;">
                <Label text="👥" style="-fx-font-size: 14; -fx-text-fill: #3D7FB8;"/>
                <Label text="Patients" style="-fx-font-size: 13; -fx-text-fill: #3D7FB8;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="patientCountBadge" text="0"
                       style="-fx-background-color: #A7DAF9; -fx-text-fill: #3D7FB8; -fx-font-size: 10; -fx-font-weight: bold; -fx-padding: 1 6 1 6; -fx-background-radius: 10;"/>
            </HBox>

            <HBox fx:id="appointmentsNav" spacing="10" alignment="CENTER_LEFT"
                  style="-fx-padding: 9 10 9 10; -fx-cursor: hand; -fx-background-radius: 8;">
                <Label text="📅" style="-fx-font-size: 14; -fx-text-fill: #3D7FB8;"/>
                <Label text="Appointments" style="-fx-font-size: 13; -fx-text-fill: #3D7FB8;"/>
            </HBox>

            <HBox fx:id="doctorsNav" spacing="10" alignment="CENTER_LEFT"
                  style="-fx-padding: 9 10 9 10; -fx-cursor: hand; -fx-background-radius: 8;">
                <Label text="🩺" style="-fx-font-size: 14; -fx-text-fill: #3D7FB8;"/>
                <Label text="Doctors" style="-fx-font-size: 13; -fx-text-fill: #3D7FB8;"/>
            </HBox>

            <HBox fx:id="departmentsNav" spacing="10" alignment="CENTER_LEFT"
                  style="-fx-padding: 9 10 9 10; -fx-cursor: hand; -fx-background-radius: 8;">
                <Label text="🏥" style="-fx-font-size: 14; -fx-text-fill: #3D7FB8;"/>
                <Label text="Departments" style="-fx-font-size: 13; -fx-text-fill: #3D7FB8;"/>
            </HBox>
        </VBox>

        <VBox spacing="2" style="-fx-padding: 14 10 0 10;">
            <Label text="OPERATIONS" style="-fx-font-size: 10; -fx-text-fill: #78BCE8; -fx-padding: 0 8 6 8;"/>

            <HBox fx:id="wardManagementNav" spacing="10" alignment="CENTER_LEFT"
                  style="-fx-padding: 9 10 9 10; -fx-background-radius: 8; -fx-cursor: hand;">
                <Label text="🛏" style="-fx-font-size: 14; -fx-text-fill: #3D7FB8;"/>
                <Label text="Ward Management" style="-fx-font-size: 13; -fx-text-fill: #3D7FB8;"/>
            </HBox>

            <HBox fx:id="laboratoryNav" spacing="10" alignment="CENTER_LEFT"
                  style="-fx-padding: 9 10 9 10; -fx-background-radius: 8; -fx-cursor: hand;">
                <Label text="🧪" style="-fx-font-size: 14; -fx-text-fill: #3D7FB8;"/>
                <Label text="Laboratory" style="-fx-font-size: 13; -fx-text-fill: #3D7FB8;"/>
            </HBox>

            <HBox fx:id="pharmacyNav" spacing="10" alignment="CENTER_LEFT"
                  style="-fx-padding: 9 10 9 10; -fx-background-radius: 8; -fx-cursor: hand;">
                <Label text="💊" style="-fx-font-size: 14; -fx-text-fill: #3D7FB8;"/>
                <Label text="Pharmacy" style="-fx-font-size: 13; -fx-text-fill: #3D7FB8;"/>
            </HBox>

            <HBox fx:id="billingNav" spacing="10" alignment="CENTER_LEFT"
                  style="-fx-padding: 9 10 9 10; -fx-background-radius: 8; -fx-cursor: hand;">
                <Label text="🧾" style="-fx-font-size: 14; -fx-text-fill: #3D7FB8;"/>
                <Label text="Billing" style="-fx-font-size: 13; -fx-text-fill: #3D7FB8;"/>
            </HBox>
        </VBox>

        <VBox spacing="2" style="-fx-padding: 14 10 0 10;">
            <Label text="SYSTEM" style="-fx-font-size: 10; -fx-text-fill: #78BCE8; -fx-padding: 0 8 6 8;"/>

            <HBox fx:id="reportsNav" spacing="10" alignment="CENTER_LEFT"
                  style="-fx-padding: 9 10 9 10; -fx-background-radius: 8; -fx-cursor: hand;">
                <Label text="📊" style="-fx-font-size: 14; -fx-text-fill: #3D7FB8;"/>
                <Label text="Reports" style="-fx-font-size: 13; -fx-text-fill: #3D7FB8;"/>
            </HBox>

            <HBox fx:id="settingsNav" spacing="10" alignment="CENTER_LEFT"
                  style="-fx-padding: 9 10 9 10; -fx-background-radius: 8; -fx-cursor: hand;">
                <Label text="⚙" style="-fx-font-size: 14; -fx-text-fill: #3D7FB8;"/>
                <Label text="Settings" style="-fx-font-size: 13; -fx-text-fill: #3D7FB8;"/>
            </HBox>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <HBox fx:id="userProfileSection" spacing="10" alignment="CENTER_LEFT"
              style="-fx-padding: 14 18 14 18; -fx-background-color: #F8FDFF; -fx-border-color: #D6ECFA; -fx-border-width: 1 0 0 0; -fx-cursor: hand;">
            <StackPane prefWidth="38" prefHeight="38"
                       style="-fx-background-color: #7CC8F8; -fx-background-radius: 19;">
                <Label fx:id="avatarLabel" text="AK"
                       style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: white;"/>
            </StackPane>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label fx:id="userNameLabel" text="User"
                       style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #3D7FB8;"/>
                <Label fx:id="userRoleLabel" text="Role"
                       style="-fx-font-size: 11; -fx-text-fill: #78BCE8;"/>
                <Label text="Click to log out" style="-fx-font-size: 9; -fx-text-fill: #AAAAAA;"/>
            </VBox>
            <Circle radius="4" fill="#7CC8F8"/>
        </HBox>
    </VBox>

    <VBox HBox.hgrow="ALWAYS" spacing="0">
        <HBox alignment="CENTER_LEFT" spacing="14" prefHeight="56"
              style="-fx-background-color: white; -fx-padding: 0 24 0 24; -fx-border-color: #e0e8f0; -fx-border-width: 0 0 1 0;">
            <Label fx:id="greetingLabel" text="Good morning"
                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #042C53;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="dateLabel" text=""
                   style="-fx-font-size: 12; -fx-text-fill: #888;"/>
            <HBox alignment="CENTER_LEFT" spacing="6"
                  style="-fx-background-color: #E6F1FB; -fx-background-radius: 20; -fx-padding: 5 12 5 12; -fx-border-color: #B5D4F4; -fx-border-radius: 20; -fx-border-width: 1;">
                <Label text="🔍" style="-fx-font-size: 13;"/>
                <TextField fx:id="globalSearchField" promptText="Search patients..."
                           onAction="#handleGlobalSearch" prefWidth="180"
                           style="-fx-background-color: transparent; -fx-border-width: 0; -fx-font-size: 13;"/>
            </HBox>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: #f0f6ff; -fx-background: #f0f6ff;">
            <VBox spacing="16" style="-fx-padding: 20 24 24 24; -fx-background-color: #f0f6ff;">

                <HBox fx:id="kpiRow" spacing="12">
                    <VBox HBox.hgrow="ALWAYS" spacing="8"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 14 16; -fx-border-color: #e0e8f0; -fx-border-width: 1; -fx-border-radius: 12;">
                        <Label text="👥" style="-fx-font-size: 17;"/>
                        <Label fx:id="kpi1Value" text="0" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #042C53;"/>
                        <Label fx:id="kpi1Title" text="Total Patients" style="-fx-font-size: 12; -fx-text-fill: #888;"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" spacing="8"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 14 16; -fx-border-color: #e0e8f0; -fx-border-width: 1; -fx-border-radius: 12;">
                        <Label text="💊" style="-fx-font-size: 17;"/>
                        <Label fx:id="kpi2Value" text="0" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #042C53;"/>
                        <Label fx:id="kpi2Title" text="Pending Prescriptions" style="-fx-font-size: 12; -fx-text-fill: #888;"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" spacing="8"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 14 16; -fx-border-color: #e0e8f0; -fx-border-width: 1; -fx-border-radius: 12;">
                        <Label text="🧪" style="-fx-font-size: 17;"/>
                        <Label fx:id="kpi3Value" text="0" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #042C53;"/>
                        <Label fx:id="kpi3Title" text="Pending Lab Orders" style="-fx-font-size: 12; -fx-text-fill: #888;"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" spacing="8"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 14 16; -fx-border-color: #e0e8f0; -fx-border-width: 1; -fx-border-radius: 12;">
                        <Label text="📊" style="-fx-font-size: 17;"/>
                        <Label fx:id="kpi4Value" text="0" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #042C53;"/>
                        <Label fx:id="kpi4Title" text="Outstanding Billing" style="-fx-font-size: 12; -fx-text-fill: #888;"/>
                    </VBox>
                </HBox>

                <HBox spacing="16" alignment="TOP_LEFT">
                    <VBox HBox.hgrow="ALWAYS" spacing="0"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e0e8f0; -fx-border-width: 1; -fx-border-radius: 12;">
                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 14 16 10 16;">
                            <Label fx:id="activityPanelTitle" text="Recent Activity"
                                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #042C53;"/>
                        </HBox>
                        <VBox fx:id="activityList" style="-fx-padding: 0 16 14 16;" spacing="0"/>
                    </VBox>

                    <VBox HBox.hgrow="ALWAYS" spacing="16">
                        <VBox spacing="0"
                              style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e0e8f0; -fx-border-width: 1; -fx-border-radius: 12;">
                            <HBox alignment="CENTER_LEFT" style="-fx-padding: 14 16 10 16;">
                                <Label text="Ward Occupancy"
                                       style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #042C53;"/>
                            </HBox>
                            <VBox fx:id="wardOccupancyList" style="-fx-padding: 0 16 14 16;" spacing="10"/>
                        </VBox>

                        <VBox spacing="0"
                              style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e0e8f0; -fx-border-width: 1; -fx-border-radius: 12;">
                            <HBox alignment="CENTER_LEFT" style="-fx-padding: 14 16 10 16;">
                                <Label text="Quick Stats"
                                       style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #042C53;"/>
                            </HBox>
                            <GridPane hgap="10" vgap="10" style="-fx-padding: 0 16 16 16;">
                                <columnConstraints>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                                </columnConstraints>
                                <VBox spacing="2" style="-fx-background-color: #E6F1FB; -fx-background-radius: 8; -fx-padding: 12;"
                                      GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <Label fx:id="stat1Value" text="0" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #0C447C;"/>
                                    <Label fx:id="stat1Title" text="Patients" style="-fx-font-size: 11; -fx-text-fill: #185FA5;"/>
                                </VBox>
                                <VBox spacing="2" style="-fx-background-color: #E6F1FB; -fx-background-radius: 8; -fx-padding: 12;"
                                      GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <Label fx:id="stat2Value" text="0" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #0C447C;"/>
                                    <Label fx:id="stat2Title" text="Pending prescriptions" style="-fx-font-size: 11; -fx-text-fill: #185FA5;"/>
                                </VBox>
                                <VBox spacing="2" style="-fx-background-color: #E6F1FB; -fx-background-radius: 8; -fx-padding: 12;"
                                      GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <Label fx:id="stat3Value" text="0" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #0C447C;"/>
                                    <Label fx:id="stat3Title" text="Pending lab orders" style="-fx-font-size: 11; -fx-text-fill: #185FA5;"/>
                                </VBox>
                                <VBox spacing="2" style="-fx-background-color: #E6F1FB; -fx-background-radius: 8; -fx-padding: 12;"
                                      GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <Label fx:id="stat4Value" text="0%" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #0C447C;"/>
                                    <Label fx:id="stat4Title" text="Lab completion rate" style="-fx-font-size: 11; -fx-text-fill: #185FA5;"/>
                                </VBox>
                            </GridPane>
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </VBox>
</HBox>
